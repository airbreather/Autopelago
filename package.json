{
  "name": "autopelago",
  "version": "0.0.0",
  "builders": "./builders.json",
  "web-types": "./web-types.json",
  "browserslist": [
    "baseline widely available on 2026-05-07"
  ],
  "scripts": {
    "ng": "ng",
    "bake-color-masks": "bun run src/generate-color-masks.ts > src/app/utils/color-masks.json",
    "bake-game-data": "yq . AutopelagoDefinitions.yml --output-format json --indent 0 > src/app/data/baked.json",
    "bake-data": "$npm_execpath run bake-color-masks && $npm_execpath run bake-game-data",
    "postinstall": "$npm_execpath run bake-data",
    "prestart": "$npm_execpath run bake-data",
    "prebuild": "$npm_execpath run bake-data",
    "prewatch": "$npm_execpath run bake-data",
    "pretest": "$npm_execpath run bake-data",
    "start": "ng serve --no-hmr",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint": "ng lint",
    "test": "ng test",
    "stamp-version": "jq -R -s 'split(\"\n\") | { \"version\": .[0], \"commit\": .[1], \"timestamp\": .[2] }' <(echo $GITHUB_REF_NAME) <(echo $GITHUB_SHA) <(date --utc --rfc-3339=seconds) >src/version-info.json",
    "prerelease": "$npm_execpath run stamp-version",
    "release": "$npm_execpath run build"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@airbreather/archipelago.js": "2.0.5-airbreather.6",
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/service-worker": "^22.0.1",
    "@bitarray/typedarray": "^1.1.3",
    "@ctrl/tinycolor": "^4.2.0",
    "@ngrx/signals": "^21.1.1",
    "angular-split": "^20.0.0",
    "immutable": "^5.1.6",
    "ngx-toastr": "^20.0.5",
    "node-forge": "^1.4.0",
    "normalize.css": "^8.0.1",
    "pure-rand": "^8.4.0",
    "scroll-into-view-if-needed": "^3.1.0",
    "tslib": "^2.8.1",
    "yocto-queue": "^1.2.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.14",
    "@types/node-forge": "^1.3.14",
    "angular-eslint": "22.0.0",
    "eslint": "^10.5.0",
    "happy-dom": "^20.10.3",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "core-js",
    "esbuild",
    "lmdb",
    "msgpackr-extract",
    "sharp"
  ]
}
